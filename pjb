def find_docs_dir():
    for candidate in DOCS_CANDIDATES:
        if candidate.is_dir():
            return candidate
    return None


def cmd_search(query):
    docs_dir = find_docs_dir()
    if docs_dir is None:
        print("Error: Could not find docs/src directory.")
        print("Run this from the PyJavaBridge project root.")
        sys.exit(1)

    query_lower = query.lower()
    results = []

    for md_file in sorted(docs_dir.glob("*.md")):
        content = md_file.read_text(encoding="utf-8")
        lines = content.split("\n")

        for i, line in enumerate(lines):
            if query_lower in line.lower():
                # Get context: heading above this line
                heading = md_file.stem
                for j in range(i, -1, -1):
                    if lines[j].startswith("#"):
                        heading = lines[j].lstrip("#").strip()
                        break

                # Clean the matched line
                clean_line = line.strip()
                if not clean_line or clean_line.startswith("---"):
                    continue

                results.append({
                    "file": md_file.stem,
                    "line": i + 1,
                    "heading": heading,
                    "text": clean_line[:120],
                })

    if not results:
        print(f"No results for '{query}'")
        return

    print(f"\033[1m{len(results)} result(s) for '{query}':\033[0m\n")

    current_file = None
    for r in results:
        if r["file"] != current_file:
            current_file = r["file"]
            print(f"\033[36m  {current_file}.md\033[0m")
        # Highlight the match in the text
        text = r["text"]
        highlighted = re.sub(
            re.escape(query),
            f"\033[33m{query}\033[0m",
            text,
            flags=re.IGNORECASE,
        )
        print(f"    L{r['line']:>3}  \033[90m{r['heading']}\033[0m  {highlighted}")


def cmd_events(filter_str=None):
    filter_lower = filter_str.lower() if filter_str else None

    matching = {}
    for name, info in sorted(EVENTS.items()):
        if filter_lower:
            if filter_lower not in name and filter_lower not in info["desc"].lower():
                if not any(filter_lower in f for f in info["fields"]):
                    continue
        matching[name] = info

    if not matching:
        print(f"No events matching '{filter_str}'")
        return

    print(f"\033[1m{len(matching)} event(s){'  (filter: ' + filter_str + ')' if filter_str else ''}:\033[0m\n")

    for name, info in matching.items():
        cancel = "\033[32m✓\033[0m" if info["cancellable"] else "\033[90m✗\033[0m"
        fields = ", ".join(info["fields"]) if info["fields"] else "(none)"
        print(f"  {cancel} \033[36m{name}\033[0m")
        print(f"      {info['desc']}")
        print(f"      \033[90mfields: {fields}\033[0m")


def main():
    if len(sys.argv) < 2:
        print(__doc__)
        sys.exit(1)

    cmd = sys.argv[1].lower()

    if cmd == "search":
        if len(sys.argv) < 3:
            print("Usage: pjb search <query>")
            sys.exit(1)
        cmd_search(" ".join(sys.argv[2:]))

    elif cmd == "events":
        filter_str = " ".join(sys.argv[2:]) if len(sys.argv) > 2 else None
        cmd_events(filter_str)

    else:
        print(f"Unknown command: {cmd}")
        print(__doc__)
        sys.exit(1)


if __name__ == "__main__":
    main()
